<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0a"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TAG REAPER SENTINEL"
        android:textColor="#4a9eff"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not connected"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/txtSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session: none"
        android:textColor="#f0f0f0"
        android:textSize="13sp"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Connect" />

        <Button
            android:id="@+id/btnNewSession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Session" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Start Scan"
            android:enabled="false" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pause"
            android:enabled="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnEndSession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="End Session"
            android:enabled="false" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear Test Data" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Antennas"
        android:textColor="#4a9eff"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <CheckBox
            android:id="@+id/chkAnt1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ANT 1"
            android:textColor="#f0f0f0"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ANT 2"
            android:textColor="#f0f0f0"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ANT 3"
            android:textColor="#f0f0f0"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ANT 4"
            android:textColor="#f0f0f0"
            android:checked="true" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Antenna Power"
        android:textColor="#4a9eff"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="ANT 1" android:textColor="#f0f0f0"/>
        <SeekBar android:id="@+id/seekAnt1Power" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/txtAnt1Power" android:layout_width="64dp" android:layout_height="wrap_content" android:text="30 dBm" android:textColor="#f0f0f0"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="ANT 2" android:textColor="#f0f0f0"/>
        <SeekBar android:id="@+id/seekAnt2Power" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/txtAnt2Power" android:layout_width="64dp" android:layout_height="wrap_content" android:text="30 dBm" android:textColor="#f0f0f0"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="ANT 3" android:textColor="#f0f0f0"/>
        <SeekBar android:id="@+id/seekAnt3Power" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/txtAnt3Power" android:layout_width="64dp" android:layout_height="wrap_content" android:text="30 dBm" android:textColor="#f0f0f0"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="ANT 4" android:textColor="#f0f0f0"/>
        <SeekBar android:id="@+id/seekAnt4Power" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/txtAnt4Power" android:layout_width="64dp" android:layout_height="wrap_content" android:text="30 dBm" android:textColor="#f0f0f0"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/txtTotalReads"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total Reads: 0"
            android:textColor="#f0f0f0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtUniqueTags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Unique Tags: 0"
            android:textColor="#4a9eff"
            android:textSize="14sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/listTags"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#2a2a2a"
        android:dividerHeight="1dp" />

</LinearLayout>
