<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080b10"
    android:padding="8dp">

    <TextView
        android:id="@+id/txtHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="34dp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#111827"
        android:text="TAG REAPER SENTINEL | Not connected | No session"
        android:textColor="#38bdf8"
        android:textSize="15sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <!-- v0.6 GPS and SageWire context bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0f172a"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/txtContextStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="CONTEXT | GPS not captured"
            android:textColor="#e5e7eb"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnCaptureContext"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:text="Capture GPS"
            android:textSize="10sp"
            android:padding="2dp" />

        <Button
            android:id="@+id/btnRetryContext"
            android:layout_width="105dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:text="Retry Sync"
            android:textSize="10sp"
            android:padding="2dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Main reader and session controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Connect"
            android:textSize="11sp"
            android:padding="2dp" />

        <Button
            android:id="@+id/btnNewSession"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="New Session"
            android:textSize="11sp"
            android:padding="2dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Start Scan"
            android:textSize="11sp"
            android:padding="2dp"
            android:enabled="false" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Pause"
            android:textSize="11sp"
            android:padding="2dp"
            android:enabled="false" />

        <Button
            android:id="@+id/btnEndSession"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="End Session"
            android:textSize="11sp"
            android:padding="2dp"
            android:enabled="false" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="Clear"
            android:textSize="11sp"
            android:padding="2dp" />
    </LinearLayout>

    <!-- Profile, history, and export controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnProfiles"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Profiles"
            android:textSize="10sp"
            android:padding="2dp" />

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="History"
            android:textSize="10sp"
            android:padding="2dp" />

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="CSV"
            android:textSize="10sp"
            android:padding="2dp"
            android:enabled="false" />

        <Button
            android:id="@+id/btnExportJson"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="JSON"
            android:textSize="10sp"
            android:padding="2dp"
            android:enabled="false" />

        <Button
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Share"
            android:textSize="10sp"
            android:padding="2dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Antenna enable controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0f172a"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="ANTENNAS"
            android:textColor="#38bdf8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/chkAnt1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="ANT 1"
            android:textColor="#e5e7eb"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="ANT 2"
            android:textColor="#e5e7eb"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt3"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="ANT 3"
            android:textColor="#e5e7eb"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/chkAnt4"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="ANT 4"
            android:textColor="#e5e7eb"
            android:textSize="11sp"
            android:checked="true" />
    </LinearLayout>

    <!-- Independent antenna power controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0f172a"
        android:padding="4dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/txtAnt1Power"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ANT 1 • 30 dBm"
                android:textColor="#f8fafc"
                android:textSize="11sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekAnt1Power"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:max="25"
                android:progress="25" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/txtAnt2Power"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ANT 2 • 30 dBm"
                android:textColor="#f8fafc"
                android:textSize="11sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekAnt2Power"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:max="25"
                android:progress="25" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/txtAnt3Power"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ANT 3 • 30 dBm"
                android:textColor="#f8fafc"
                android:textSize="11sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekAnt3Power"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:max="25"
                android:progress="25" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAnt4Power"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ANT 4 • 30 dBm"
                android:textColor="#f8fafc"
                android:textSize="11sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekAnt4Power"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:max="25"
                android:progress="25" />
        </LinearLayout>
    </LinearLayout>

    <!-- Search and sort controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111827"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:layout_marginBottom="2dp">

        <EditText
            android:id="@+id/editSearch"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="#1f2937"
            android:hint="Search EPC or tag number"
            android:textColor="#f8fafc"
            android:textColorHint="#94a3b8"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSort"
            android:layout_width="120dp"
            android:layout_height="34dp"
            android:text="Sort: First"
            android:textSize="10sp"
            android:padding="2dp" />
    </LinearLayout>

    <!-- Tag ledger summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111827"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TAG OBSERVATIONS"
            android:textColor="#38bdf8"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTotalReads"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:text="Reads: 0"
            android:textColor="#e5e7eb"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtUniqueTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tags: 0"
            android:textColor="#e5e7eb"
            android:textSize="12sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/listTags"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#05070a"
        android:divider="#263244"
        android:dividerHeight="1dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:fastScrollEnabled="true"
        android:scrollbars="vertical" />

</LinearLayout>
